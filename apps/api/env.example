# apps/api/env.example
# ローカル開発用（値は各自の環境に合わせて設定）
#
# 使い方:
# - `apps/api/.env` を作成し、この内容をコピーして値を埋めてください。

# サーバー設定
PORT=3001
HOST=0.0.0.0

# Supabase設定
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# 任意（last_login 更新などで利用。未設定でも起動は可能）
SUPABASE_SERVICE_ROLE_KEY=

# JWT設定
# 必須: 32文字以上のランダム値（例: `openssl rand -hex 32`）
# ※「change-me」等の推測可能な値は起動時に拒否されます
JWT_SECRET=
JWT_ACCESS_EXPIRY=3600
JWT_REFRESH_EXPIRY=2592000

# CORS設定（必要に応じて）
CORS_ORIGINS=http://localhost:3000

# デバッグ（原因特定用: エラー詳細をレスポンスに含める）
# 本番では必ず 0（未設定）にしてください
API_DEBUG_ERRORS=0
ENVIRONMENT=local

# ログ
RUST_LOG=info,spirom_api=debug,tower_http=info

# ============================================
# Security Configuration
# ============================================

# セッション署名用シークレット（必須）
# 生成: openssl rand -hex 32
SESSION_SECRET=

# BFFプロキシトークン（本番では必須）
# Next.js経由のリクエストのみ許可するためのトークン
# Next.js側と同じ値を設定
# 生成: openssl rand -hex 32
BFF_PROXY_TOKEN=

# 信頼できるプロキシIP（カンマ区切り）
# X-Forwarded-Forヘッダーを信用するプロキシのIP
# Fly.io: fdaa::
# Cloudflare: https://www.cloudflare.com/ips/
# ローカル: 127.0.0.1,::1
TRUSTED_PROXY_IPS=127.0.0.1,::1

# ============================================
# Stripe Configuration
# ============================================

# Stripe Secret Key（必須）
# 本番: sk_live_...
# テスト: sk_test_...
# 重要: フロントエンド(NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY)と同じ環境(test/live)のキーを使用すること
STRIPE_SECRET_KEY=

# Stripe Webhook Secret（Webhook使用時は必須）
# Stripeダッシュボードの「Webhooks」で取得
STRIPE_WEBHOOK_SECRET=

# 複数のWebhook Secretを使用する場合（カンマ区切り）
# STRIPE_WEBHOOK_SECRETS=whsec_xxx,whsec_yyy

# ============================================
# JPYC (Crypto Payment) Configuration
# ============================================

# JPYC受取用ウォレットアドレス（Polygon）- 必須
# MetaMaskなどで作成したウォレットのアドレス
# 例: 0x1234567890abcdef1234567890abcdef12345678
JPYC_RECIPIENT_ADDRESS=

# テストモード（true = Polygon Amoy Testnet, false/未設定 = Polygon Mainnet）
# 開発時はtrueに設定
JPYC_TEST_MODE=false

# Polygon RPC URL（任意: デフォルト値あり）
# テスト時: https://rpc-amoy.polygon.technology
# 本番時: https://polygon-rpc.com
# Alchemy: https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# POLYGON_RPC_URL=https://polygon-rpc.com

# 確認数（任意: デフォルト値あり）
# テスト時: 2、本番時: 12
# JPYC_REQUIRED_CONFIRMATIONS=12
